{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "outDir": "dist/cron",
    "rootDir": "cron",
    "moduleResolution": "node",
    "types": ["node"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@/*": ["./cron/*"]
    }
  },
  "include": ["cron/**/*.ts"]
}
